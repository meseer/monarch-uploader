{
  "name": "monarch-uploader",
  "version": "3.6.0",
  "description": "Tampermonkey userscript for uploading Questrade balance history to Monarch Money",
  "main": "dist/questrade-account-balance-uploader.user.js",
  "scripts": {
    "build": "npm run clean && webpack --mode production",
    "build:dev": "webpack --mode development",
    "build:full": "npm run clean && npm run lint && npm run test && webpack --mode production",
    "watch": "webpack --mode development --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist/",
    "postbuild": "echo 'Build complete! Output in dist/'",
    "build:quick": "npm run clean && npm run build:dev"
  },
  "keywords": [
    "tampermonkey",
    "userscript",
    "questrade",
    "monarch-money"
  ],
  "author": "You",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/preset-env": "^7.23.7",
    "babel-loader": "^9.1.3",
    "eslint": "^9.35.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.0.5",
    "terser-webpack-plugin": "^5.3.10",
    "webpack": "^5.89.0",
    "webpack-cli": "^6.0.1"
  }
}
