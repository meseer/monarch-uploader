{
  "name": "monarch-uploader",
  "version": "3.8.0",
  "description": "Tampermonkey userscript for uploading Questrade balance history to Monarch Money",
  "main": "dist/monarch-uploader.user.js",
  "scripts": {
    "build": "npm run clean && webpack --mode production",
    "build:dev": "webpack --mode development",
    "build:full": "npm run clean && npm run lint && npm run test && webpack --mode production",
    "watch": "webpack --mode development --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist/",
    "postbuild": "echo 'Build complete! Output in dist/'",
    "build:quick": "npm run clean && npm run build:dev"
  },
  "keywords": [
    "tampermonkey",
    "userscript",
    "questrade",
    "monarch-money"
  ],
  "author": "You",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "babel-loader": "^10.0.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "terser-webpack-plugin": "^5.3.14",
    "webpack": "^5.101.3",
    "webpack-cli": "^6.0.1"
  },
  "overrides": {
    "rimraf": "^5.0.0",
    "glob": "^10.0.0",
    "inflight": "npm:@isaacs/inflight@^1.0.6"
  }
}
